# --- GitLab ---
# Falls back to CI_SERVER_URL / CI_PROJECT_ID / CI_MERGE_REQUEST_IID when run
# inside a GitLab CI/CD job, so these usually only need to be set for local testing.
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
CI_PROJECT_ID=123
CI_MERGE_REQUEST_IID=45

# --- Internal vLLM (OpenAI-compatible) service ---
# Base URL must include the /v1 suffix that vLLM's OpenAI-compatible server exposes.
VLLM_BASE_URL=http://vllm.internal.svc.cluster.local:8000/v1
# Model name as served by vLLM (the value passed to `--served-model-name`).
VLLM_MODEL=Qwen2.5-Coder-32B-Instruct
# Usually unused for an internal server; leave as-is unless your gateway requires a key.
VLLM_API_KEY=not-needed

# --- Optional vLLM tuning ---
VLLM_TIMEOUT=120
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.2

# --- Optional review tuning ---
REVIEW_BOT_CONFIG_PATH=.gitlab/review-bot.yml
MAX_DIFF_CHARS=60000
MAX_COMMENTS=25
POST_INLINE_COMMENTS=true
POST_SUMMARY_COMMENT=true
