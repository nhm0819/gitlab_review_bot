# --- GitLab ---
# Falls back to CI_SERVER_URL / CI_PROJECT_ID / CI_MERGE_REQUEST_IID when run
# inside a GitLab CI/CD job, so these usually only need to be set for local testing.
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
CI_PROJECT_ID=123
CI_MERGE_REQUEST_IID=45

# --- Internal vLLM (OpenAI-compatible) service ---
# Base URL must include the /v1 suffix that vLLM's OpenAI-compatible server exposes.
VLLM_BASE_URL=http://vllm.internal.svc.cluster.local:8000/v1
# Must match what vLLM serves (`vllm serve <model>` or --served-model-name).
VLLM_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
# Usually unused for an internal server; leave as-is unless your gateway requires a key.
VLLM_API_KEY=not-needed

# --- Sampling: Qwen3.6 "thinking mode for precise coding tasks" preset ---
VLLM_TEMPERATURE=0.6
VLLM_TOP_P=0.95
VLLM_TOP_K=20
VLLM_PRESENCE_PENALTY=0.0

# Qwen3.6 thinks by default. Thinking tokens count toward max_tokens, so this
# must stay generous. Set VLLM_ENABLE_THINKING=false for faster, cheaper runs.
VLLM_ENABLE_THINKING=true
VLLM_MAX_TOKENS=32768

# Seconds. Minimum enforced value is 300; lower values are raised to 300.
VLLM_TIMEOUT=600

# --- Optional review tuning ---
REVIEW_BOT_CONFIG_PATH=.gitlab/review-bot.yml
# Bounded by the model's 262,144-token context window.
MAX_DIFF_CHARS=200000
MAX_COMMENTS=25
POST_INLINE_COMMENTS=true
POST_SUMMARY_COMMENT=true

# --- Optional MR title/description generation ---
DESCRIBE_LANGUAGE=Korean

# --- Large-diff handling ---
# Per-request diff budget; larger changes are split across batches and merged.
MAX_FILE_DIFF_CHARS=40000
MAX_BATCHES=8
